# Note: convex/_generated/ is committed. The CLI (`convex dev` / `convex deploy`)
# regenerates these files in place; they're tracked so a fresh checkout
# typechecks without needing the Convex CLI to be configured first.

# Service worker is generated by @serwist/next at build time.
public/sw.js
public/sw.js.map
public/swe-worker-*.js

