# --- Convex ---
# From `npx convex dev` (writes to .env.local automatically) or the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=

# Used by Vercel build step to deploy Convex functions. Set in Vercel project settings only.
CONVEX_DEPLOY_KEY=

# --- Clerk ---
# https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# https://dashboard.clerk.com -> Webhooks (used to sync users into Convex).
# IMPORTANT: this value is consumed by Convex (not Next.js). Set it via:
#   npx convex env set CLERK_WEBHOOK_SECRET whsec_...
# Configure the webhook URL in Clerk to: https://<your-deployment>.convex.site/clerk
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs (kept in env so Vercel previews can override)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Clerk Frontend API URL — required by Convex's auth integration.
# Find it in Clerk dashboard -> API Keys -> "Frontend API".
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=

# --- Resend ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender, e.g. "ClickUp Clone <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=

# --- Platform administration (SOC2) ---
# Root of trust for the admin console. Comma-separated emails; anyone on
# this list is a superadmin and can grant scoped admin to others in-app.
# There is NO in-app path to become an admin without this list or an
# existing superadmin's grant. Consumed by Convex — set it via:
#   npx convex env set PLATFORM_ADMIN_EMAILS you@company.com,ops@company.com
PLATFORM_ADMIN_EMAILS=

# --- x402 agent payments ---
# Agents top up a prepaid credit wallet by paying via the x402 protocol.
# All optional: with no facilitator URL the flow runs against a built-in
# MOCK facilitator (great for dev/testing), and the rest have testnet
# defaults. Set these on the CONVEX deployment (npx convex env set ...) —
# the settlement action reads them server-side; none are NEXT_PUBLIC.
#
# Payment facilitator that verifies + settles on-chain payments. Leave unset
# to use the mock facilitator (no real settlement).
X402_FACILITATOR_URL=
# Network + asset agents pay in (defaults: Base Sepolia USDC).
X402_NETWORK=base-sepolia
X402_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_ASSET_SYMBOL=USDC
X402_ASSET_DECIMALS=6
# Receiving address credited on settlement. MUST be set for production.
X402_PAY_TO=
# Atomic asset units charged per 1 platform credit (default 1000 = $0.001
# per credit for 6-decimal USDC, i.e. 1000 credits = $1.00).
X402_CREDIT_PRICE_ATOMIC=1000
# Credits consumed per metered agent write action (default 1). Metering is
# OFF until a superadmin enables it in the admin console.
X402_ACTION_CREDITS=1
